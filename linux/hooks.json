{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash ~/.cursor/inject-doctrine.sh",
        "timeout": 5
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash ~/.agents/hooks/scope-refresh.sh",
        "timeout": 5,
        "matcher": "^Write$"
      }
    ],
    "postToolUse": [
      {
        "command": "bash ~/.agents/hooks/scope-drain.sh",
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "bash ~/.agents/hooks/permission-gate.sh",
        "timeout": 5,
        "failClosed": true
      }
    ],
    "stop": [
      {
        "command": "bash ~/.agents/hooks/final-review.sh",
        "timeout": 10,
        "loop_limit": 2
      }
    ]
  }
}
