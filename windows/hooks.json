{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/intent-precompile.ps1",
        "timeout": 5
      }
    ],
    "sessionStart": [
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.cursor/inject-doctrine.ps1",
        "timeout": 5
      }
    ],
    "afterFileEdit": [
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/self-review-trigger.ps1",
        "timeout": 5,
        "matcher": "^Write$"
      },
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/semantic-density-audit.ps1",
        "timeout": 15,
        "matcher": "^Write$"
      },
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/scope-gate-audit.ps1",
        "timeout": 10,
        "matcher": "^Write$"
      },
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/anti-slop-audit.ps1",
        "timeout": 15,
        "matcher": "^Write$"
      }
    ],
    "postToolUse": [
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/intent-anchor.ps1",
        "timeout": 5
      },
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/post-tool-use.ps1",
        "timeout": 5
      }
    ],
    "subagentStop": [
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/subagent-stop-review.ps1",
        "timeout": 5,
        "loop_limit": 3
      }
    ],
    "beforeShellExecution": [
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/permission-gate.ps1",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "stop": [
      {
        "command": "pwsh.exe -NoProfile -File C:/Users/Administrator/.agents/hooks/final-review.ps1",
        "timeout": 10,
        "loop_limit": 5
      }
    ]
  }
}
