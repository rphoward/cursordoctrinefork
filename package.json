{
  "name": "cursordoctrine",
  "version": "2.0.0",
  "description": "Cursor hooks: doctrine at session start, intent-precompile (.scope.json), Step 0 hard gate, scope refresh/drain, mid-session milestone verify, permission gate, final review at stop.",
  "bin": {
    "cursordoctrine": "bin/cli.mjs"
  },
  "type": "module",
  "scripts": {
    "test": "node bin/cli.mjs install && node bin/cli.mjs verify",
    "verify": "node bin/cli.mjs verify",
    "sweep": "node bin/cli.mjs sweep"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "hooks/",
    "hooks.json",
    "skills/anti-slop/",
    "docs/AUDIT-PROMPT.md",
    "docs/MCP.md",
    "docs/USER-RULES.md",
    "INSTALL.md",
    "!**/__pycache__",
    "!**/*.pyc",
    "!**/*.pyo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kleosr/cursordoctrine.git"
  },
  "homepage": "https://github.com/kleosr/cursordoctrine#readme",
  "bugs": {
    "url": "https://github.com/kleosr/cursordoctrine/issues"
  },
  "keywords": [
    "cursor",
    "cursor-hooks",
    "hooks",
    "agent",
    "ai-agents",
    "self-review",
    "anti-slop",
    "code-review",
    "cli"
  ],
  "author": "Mario Pulice (kleosr)",
  "license": "MIT"
}
