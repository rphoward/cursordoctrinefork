{
  "name": "cursordoctrine-lite",
  "version": "3.0.0",
  "description": "Cursor hook pack lite: doctrine at session start, Step 0 hard gate on writes, shell deny-list without force-push, one final review at stop.",
  "bin": {
    "cursordoctrine": "bin/cli.mjs"
  },
  "type": "module",
  "scripts": {
    "test": "node bin/cli.mjs verify",
    "verify": "node bin/cli.mjs verify",
    "install": "node bin/cli.mjs install",
    "uninstall": "node bin/cli.mjs uninstall"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "hooks/",
    "hooks.json",
    "docs/",
    "INSTALL.md",
    "README.md",
    "HOOKS.md",
    "GLOBAL-RULES.md",
    "!**/__pycache__",
    "!**/*.pyc",
    "!**/*.pyo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kleosr/cursordoctrine.git"
  },
  "homepage": "https://github.com/kleosr/cursordoctrine#readme",
  "bugs": {
    "url": "https://github.com/kleosr/cursordoctrine/issues"
  },
  "keywords": [
    "cursor",
    "cursor-hooks",
    "hooks",
    "agent",
    "ai-agents",
    "self-review",
    "code-review"
  ],
  "author": "Mario Pulice (kleosr)",
  "license": "MIT"
}
