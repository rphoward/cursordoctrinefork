{
  "name": "cursordoctrine",
  "version": "0.7.0",
  "description": "Self-review hooks for Cursor. The agent audits its own edits: intent contract per prompt (.scope.json), advisories after each edit, and a final review with intent trace.",
  "bin": {
    "cursordoctrine": "bin/cli.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "windows/",
    "linux/",
    "skills/",
    "INSTALL.md",
    "!**/__pycache__",
    "!**/*.pyc",
    "!**/*.pyo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kleosr/cursordoctrine.git"
  },
  "homepage": "https://github.com/kleosr/cursordoctrine#readme",
  "bugs": {
    "url": "https://github.com/kleosr/cursordoctrine/issues"
  },
  "keywords": [
    "cursor",
    "cursor-hooks",
    "hooks",
    "agent",
    "ai-agents",
    "self-review",
    "anti-slop",
    "code-review",
    "cli"
  ],
  "author": "Mario Pulice (kleosr)",
  "license": "MIT"
}
