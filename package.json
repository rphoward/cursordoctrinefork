{
  "name": "cursordoctrine",
  "version": "1.4.4",
  "description": "Cursor hooks: doctrine at session start, intent-precompile (.scope.json), scope refresh/drain, mid-session milestone verify, permission gate, final review at stop.",
  "bin": {
    "cursordoctrine": "bin/cli.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "windows/",
    "linux/",
    "skills/",
    "docs/AUDIT-PROMPT.md",
    "docs/MCP.md",
    "docs/USER-RULES.md",
    "INSTALL.md",
    "!**/__pycache__",
    "!**/*.pyc",
    "!**/*.pyo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kleosr/cursordoctrine.git"
  },
  "homepage": "https://github.com/kleosr/cursordoctrine#readme",
  "bugs": {
    "url": "https://github.com/kleosr/cursordoctrine/issues"
  },
  "keywords": [
    "cursor",
    "cursor-hooks",
    "hooks",
    "agent",
    "ai-agents",
    "self-review",
    "anti-slop",
    "code-review",
    "cli"
  ],
  "author": "Mario Pulice (kleosr)",
  "license": "MIT"
}
